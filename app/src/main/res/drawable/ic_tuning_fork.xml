<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!--
        Tuning fork (diapasão):
        - Two prongs from y=2 to y=12, each 2dp wide, gap of 4dp between them
        - U-connector: outer arc dips to y=15.5, inner arc dips to y=13.5
        - Stem: 2dp wide, y=15.5 to y=22
        Path uses NonZero fill — inner boundary is traced counter-clockwise to create the hollow.
    -->
    <path
        android:fillColor="#FF000000"
        android:pathData="
            M9,2 L9,12 Q9,15.5 12,15.5 Q15,15.5 15,12 L15,2
            L13,2 L13,12 Q13,13.5 12,13.5 Q11,13.5 11,12 L11,2 Z
            M11,15.5 L11,22 L13,22 L13,15.5 Z" />
</vector>
